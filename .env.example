# Environment variables for AI Trading Bot
# P0-5 FIX: All sensitive values MUST be replaced before use

# Database (REQUIRED)
DB_PASSWORD=your_secure_database_password
DATABASE_URL=postgresql://trader:your_secure_database_password@localhost:5432/trading_bot

# Security (REQUIRED - must be 32+ chars in production)
SECRET_KEY=your-production-secret-key-minimum-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Alpha Vantage API (for market data)
ALPHAVANTAGE_API_KEY=your_alphavantage_api_key
ALPHA_VANTAGE_API_KEY=your_alphavantage_api_key

# Gemini AI API
GEMINI_AI_API_KEY=your_gemini_api_key

# Alpaca Trading API (required for live trading)
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key

# Trading Configuration
MIN_BALANCE=10.0
MAX_POSITION_SIZE=0.1
RISK_PER_TRADE=0.02
ENABLE_LIVE_TRADING=false

# Environment
ENVIRONMENT=development
DEBUG=true

# Frontend
VITE_API_URL=http://localhost:8000

# ── Trading Mode ──────────────────────────────────────────────
# CRITICAL: default is ALWAYS 'paper'. Set to 'live' only after
# paper validation is complete (sharpe>1.5, drawdown<15%, 50+ trades)
TRADING_MODE=paper

# ── Alpaca Paper Trading ───────────────────────────────────────
ALPACA_PAPER_API_KEY=your_paper_key_here
ALPACA_PAPER_SECRET_KEY=your_paper_secret_here
ALPACA_PAPER_BASE_URL=https://paper-api.alpaca.markets

# ── Paper Session Config ───────────────────────────────────────
PAPER_INITIAL_CAPITAL=10000.0
PAPER_MIN_TRADES_FOR_PROMOTE=50
PAPER_SHARPE_THRESHOLD=1.5
PAPER_DRAWDOWN_MAX=0.15
PAPER_WIN_RATE_MIN=0.45
